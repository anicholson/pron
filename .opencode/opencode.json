{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [".opencode/contree.md", "AGENTS.md"],
  "plugin": [
    "https://github.com/obra/superpowers",
    "./plugin/trunk-sync.ts",
    "./plugin/contree.ts"
  ],
  "permission": {
    "bash": {
      "git *": "deny",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git clone *": "allow"
    }
  },
  "agent": {
    "code-reviewer": {
      "description": "Reviews code for best practices and potential issues",
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash",
      "prompt": "You are a code reviewer with deep experience in idiomatic Rust. Focus on security, performance, and maintainability.",
      "permission": {
        "edit": "deny"
      }
    }
  }
}
